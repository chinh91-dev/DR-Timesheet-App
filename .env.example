# ============================================================
# DR Timesheet App — Environment Configuration
# Copy to .env.local and fill in your values
# ============================================================

# ---- DR App's Own Supabase Project ----
# (New separate project for DR tables: dr_snapshots, dr_backup_jobs, etc.)
NEXT_PUBLIC_SUPABASE_URL=https://your-dr-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dr-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dr-service-role-key

# ---- Source Database (time-team-tracker) ----
# Read-only connection to back up from
SOURCE_SUPABASE_URL=https://your-timesheet-project.supabase.co
SOURCE_SUPABASE_SERVICE_ROLE_KEY=your-timesheet-service-role-key

# ---- Supabase Storage Bucket ----
# Create a private bucket called 'dr-backups' in your DR Supabase project
DR_STORAGE_BUCKET=dr-backups

# ---- Tables to back up from time-team-tracker ----
# Core timesheet & workforce tables (98 tables total in source DB)
# Add/remove tables as needed — all table names are from TimeSheet_2026-03-09_schema.sql
BACKUP_TABLES=accounts,profiles,timesheet_entries,projects,project_assignments,tasks,leave_applications,leave_balances,leave_types,work_schedules,weekly_work_schedules,public_holidays,customers,contracts,contract_services,expenses,expense_categories,incidents,incident_history,assets,audit_logs,user_roles,invitations,contacts,services

# Full list of all 98 available tables (uncomment to back up everything):
# BACKUP_TABLES=accounts,api_idempotency_keys,api_keys,asset_attribute_defs,asset_attribute_values,asset_groups,asset_history,asset_refs,asset_statuses,asset_types,assets,assignment_notifications,assignment_queues,audit_logs,business_hours,contact_categories,contact_category_assignments,contacts,contract_assignments,contract_services,contracts,cost_calculator_company_sizes,cost_calculator_complexity_factors,cost_calculator_inhouse_config,cost_calculator_salaries,cost_calculator_settings,cost_calculator_support_types,cost_calculator_tier_features,cost_calculator_tiers,crm_meeting_notes,crm_meetings,customer_liaisons,customer_logins,customer_sla_agreements,customers,daily_location_checkins,deal_items,deal_stage_history,deal_stage_notes,deals,escalation_chains,escalation_history,escalation_rules,expense_attachments,expense_categories,expense_subcategories,expenses,incident_analytics,incident_assets,incident_comments,incident_history,incident_keywords,incident_patterns,incident_predictions,incident_priorities,incident_project_assignments,incident_projects,incident_relationships,incident_templates,incidents,integration_jobs,invitations,leave_application_attachments,leave_applications,leave_balance_operations,leave_balances,leave_types,ohs_attachments,ohs_hazard_reports,ohs_hr_incidents,ohs_injury_registers,ohs_inspection_items,ohs_inspection_results,ohs_workplace_inspections,pipeline_stages,portal_group_request_types,portal_groups,portal_request_types,profiles,project_assignments,project_sla_configs,project_sla_overrides,projects,public_holidays,service_categories,service_credits,services,skill_categories,sla_notifications,sla_overrides,task_attachments,tasks,ticket_email_log,timesheet_entries,user_holiday_permissions,user_roles,user_skills,weekly_work_schedules,work_schedules,workload_metrics

# ---- Vercel Cron Security ----
# Random secret to protect cron endpoints (generate with: openssl rand -hex 32)
CRON_SECRET=your-random-secret-here

# ---- Cron Schedules (configured in vercel.json) ----
# Backup:  0 2 * * *   = 2:00 AM daily
# Verify:  */30 * * * * = every 30 minutes
# Cleanup: 0 3 * * *   = 3:00 AM daily
